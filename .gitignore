# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used, it can be useful to ignore it.
#   https://pipenv.pypa.io/en/latest/advanced/#pipenv-keep-out

# poetry
#   Poetry uses poetry.lock to ensure reproducible builds. It's recommended to include it.
#   https://python-poetry.org/docs/basic-usage/#poetrylock-commitment

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/

